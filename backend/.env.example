# SNAJI — Variáveis de ambiente
# Copia para .env e preenche os valores reais
# NUNCA commites o .env para Git

# LLM — obrigatório
ANTHROPIC_API_KEY=sk-ant-...

# JWT — gera com: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=gera-um-secret-longo-aqui

# Base de dados PostgreSQL
DATABASE_URL=postgresql://snaji:password@localhost:5432/snaji_db

# Redis (para filas e cache)
REDIS_URL=redis://localhost:6379/0

# CORS — origens permitidas (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:5173,https://snaji.gov.pt

# Ambiente
DEBUG=false
LOG_LEVEL=INFO
ANTHROPIC_MODEL=claude-sonnet-4-20250514
